# =============================================================================
# CADDY PROXY + MANAGER — Configuration
# =============================================================================
# This file is downloaded from the repository on each install/update.
# Change values here (in the repo) and re-run caddy.sh to apply.
#
# ⚠️ DO NOT ADD SECRETS HERE — this file is public.
#    JWT_SECRET is auto-generated by caddy.sh.
# =============================================================================

# --- Deployment ---------------------------------------------------------------

# Installation path on the target server
INSTALL_DIR=/opt/caddy

# Host IP address for CORS_ORIGIN generation.
# Leave empty to auto-detect from the default network interface.
HOST_IP=

# --- Caddy Proxy --------------------------------------------------------------

# Caddy Docker image version tag (pin in production)
# See: https://hub.docker.com/_/caddy/tags
CADDY_VERSION=2

# ACME email for Let's Encrypt TLS certificate notifications
ACME_EMAIL=you@example.com

# --- CaddyManager UI ---------------------------------------------------------

# Port on the HOST where CaddyManager Web UI will be exposed
CADDYMANAGER_UI_PORT=8080

# Application display name shown in the browser tab
APP_NAME=Caddy Manager

# Enable dark mode by default in the UI (true | false)
DARK_MODE=true

# --- CaddyManager Backend ----------------------------------------------------

# Internal backend API port (not exposed to host)
BACKEND_PORT=3000

# Database engine — 'sqlite' (default, no setup) or 'mongodb'
DB_ENGINE=sqlite

# JWT token expiration duration (e.g. 24h, 7d, 30m)
JWT_EXPIRATION=24h

# --- Logging & Audit ----------------------------------------------------------

# Backend log verbosity (debug | info | warn | error)
LOG_LEVEL=info

# Maximum size of a single audit log file in MB before rotation
AUDIT_LOG_MAX_SIZE_MB=100

# Number of days to retain audit log files
AUDIT_LOG_RETENTION_DAYS=90

# --- Health Checks ------------------------------------------------------------

# Interval between Caddy server ping checks (milliseconds)
PING_INTERVAL=30000

# Timeout for each ping check (milliseconds)
PING_TIMEOUT=2000

# --- Metrics ------------------------------------------------------------------

# Maximum number of in-memory metric history snapshots
METRICS_HISTORY_MAX=1000
