# Anytype (All-in-One Bundle) Configuration
# Based on Community-first (Rule 11) for Rootless Podman stability
IMAGE_TAG="grishy/any-sync-bundle:latest"
CONTAINER_NAME="anytype"

# Arcane Metadata
ARCANE_ICON="si:anytype"
ARCANE_CATEGORY="Productivity"

# Anytype Settings
# External address used for client sync (Automatically set to HOST_IP in script)
# ANY_SYNC_BUNDLE_INIT_EXTERNAL_ADDRS is used during first run
