ANY_SYNC_CONSENSUSNODE_VERSION="prod"
ANY_SYNC_TOOLS_VERSION="latest"
MONGO_VERSION="7.0.28"
REDIS_VERSION="7.2.0-v6"
MINIO_VERSION="RELEASE.2024-07-04T14-25-45Z"

# Persistence
