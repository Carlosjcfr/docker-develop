# =============================================================================
# ARCANE - Configuration
# =============================================================================
# This file is downloaded from the repository on each install/update.
# Change values here (in the repo) and re-run install.sh to apply.
#
# ⚠️ DO NOT ADD SECRETS HERE — this file is public.
#    Secrets (ENCRYPTION_KEY, JWT_SECRET) are auto-generated by install.sh.
# =============================================================================

# --- Deployment ---------------------------------------------------------------

# Installation path on the target server
INSTALL_DIR=/opt/arcane

# Host IP address for APP_URL generation.
# Leave empty to auto-detect from the default network interface.
HOST_IP=

# Port exposed on the host for the Arcane web UI
APP_PORT=3552

# --- Application --------------------------------------------------------------

# Docker image version tag (e.g. latest, v1.0.0)
PACKAGE_VERSION=latest

# Application environment (production, development)
ENVIRONMENT=production

# Framework mode (release, debug)
GIN_MODE=release

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Timezone (e.g. Europe/Madrid, UTC, America/New_York)
TZ=Europe/Madrid

# --- Security -----------------------------------------------------------------

# JWT refresh token expiry (Go duration format: 72h, 168h, 720h)
JWT_REFRESH_EXPIRY=168h

# File and directory permissions (octal)
FILE_PERM=0644
DIR_PERM=0755

# --- TLS (optional, skip if behind a reverse proxy like Caddy) ----------------

# Enable direct TLS without a reverse proxy
TLS_ENABLED=false
# TLS_CERT_FILE=/path/to/fullchain.pem
# TLS_KEY_FILE=/path/to/privkey.pem

# --- Agent Mode (optional, for remote management) ----------------------------

# Enable agent mode to connect this instance to a central Arcane manager
AGENT_MODE=false
# AGENT_TOKEN=
