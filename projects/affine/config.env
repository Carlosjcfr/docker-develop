# AFFiNE Configuration
# Documentation: https://docs.affine.pro/docs/self-hosting/docker-compose

# Core Versions
AFFINE_VERSION=latest
POSTGRES_VERSION=16-alpine
REDIS_VERSION=7-alpine

# Networking
AFFINE_PORT=3010
AFFINE_SERVER_HOST=localhost

# Database Configuration
# NOTE: Passwords are auto-generated in affine.sh
DB_USER=affine
DB_NAME=affine

# Redis Configuration
REDIS_DB=0

# General App Settings
AFFINE_REVISION=stable
NODE_ENV=production

# Arcane Metadata
ARCANE_ICON=si:affine
ARCANE_CATEGORY=Productivity
