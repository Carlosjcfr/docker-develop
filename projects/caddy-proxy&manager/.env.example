# ==============================================================================
# CADDY PROXY + CADDY MANAGER — Environment Variables
#
# Copy this file to .env and fill in the values marked with CHANGE_ME.
# DO NOT commit .env to version control.
#
# Docs:
#   Caddy:        https://caddyserver.com/docs/running#docker-compose
#   CaddyManager: https://github.com/caddymanager/caddymanager
# ==============================================================================

# ── Caddy ──────────────────────────────────────────────────────────────────────

# Caddy Docker image version tag (pin to a specific version in production)
# See available tags: https://hub.docker.com/_/caddy/tags
CADDY_VERSION=2

# ── CaddyManager — Web UI ──────────────────────────────────────────────────────

# Port on the HOST where CaddyManager Web UI will be exposed
CADDYMANAGER_UI_PORT=8080

# Application display name shown in the browser
APP_NAME=Caddy Manager

# Enable dark mode by default in the UI (true | false)
DARK_MODE=true

# ── CaddyManager — Backend API ─────────────────────────────────────────────────

# Internal port the backend API listens on (not exposed to host)
BACKEND_PORT=3000

# Allowed CORS origin — set to the URL where the UI is accessed from the browser
# Example: http://YOUR_SERVER_IP:8080  or  https://caddy-manager.example.com
CORS_ORIGIN=http://localhost:8080

# ── Database ───────────────────────────────────────────────────────────────────

# Database engine — use 'sqlite' (default, no setup) or 'mongodb'
DB_ENGINE=sqlite

# ── Security — CHANGE ALL VALUES BEFORE DEPLOYING ──────────────────────────────

# JWT secret key — generate with: openssl rand -hex 32
# CHANGE_ME:
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# JWT token expiration duration (e.g. 24h, 7d, 30m)
JWT_EXPIRATION=24h

# ── Logging & Audit ────────────────────────────────────────────────────────────

# Backend log verbosity (debug | info | warn | error)
LOG_LEVEL=info

# Maximum size of a single audit log file in MB before rotation
AUDIT_LOG_MAX_SIZE_MB=100

# Number of days to retain audit log files
AUDIT_LOG_RETENTION_DAYS=90

# ── Health Checks ──────────────────────────────────────────────────────────────

# Interval between Caddy server ping checks (milliseconds)
PING_INTERVAL=30000

# Timeout for each ping check (milliseconds)
PING_TIMEOUT=2000

# ── Metrics ────────────────────────────────────────────────────────────────────

# Maximum number of in-memory metric history snapshots to retain
METRICS_HISTORY_MAX=1000
