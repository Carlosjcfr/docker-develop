# Airtable (APITable) Configuration defaults
AIRTABLE_PORT=8081

# APITable Image Tags (Macro-Service)
APITABLE_REGISTRY=docker.io/apitable
APITABLE_VERSION=latest
IMAGE_MINIO=docker.io/minio/minio:latest
IMAGE_REDIS=docker.io/redis:alpine
IMAGE_MYSQL=docker.io/mysql:8.0
IMAGE_RABBITMQ=docker.io/rabbitmq:management-alpine

# Arcane Metadata
ARCANE_ICON=si:airtable
ARCANE_CATEGORY=Productivity

# App settings
TIMEZONE=UTC
MYSQL_DATABASE=apitable
DATABASE_TABLE_PREFIX=apitable_
ENV=production
API_MAX_MODIFY_RECORD_COUNTS=30
INSTANCE_MAX_MEMORY=4096M
