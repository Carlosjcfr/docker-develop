# [SERVICIO]: Insforge - Backend Development Platform for AI Agents
# [CATEGORIA]: Development

# [VERSIONES]
INSFORGE_VERSION="v1.5.0"
POSTGRES_VERSION="latest"
POSTGREST_VERSION="v12.2.12"
DENO_VERSION="latest"

# [RED]
INSFORGE_PORT="7130"
INSFORGE_UI_PORT="7131"
INSFORGE_AUTH_PORT="7132"
POSTGREST_PORT="5430"
DENO_PORT="7133"

# [USER]
ADMIN_EMAIL="admin@example.com"
# ADMIN_PASSWORD= (auto-generated)

# [POSTGRES]
POSTGRES_USER="insforge_admin"
POSTGRES_DB="insforge"
# POSTGRES_PASSWORD= (auto-generated in /opt/insforge/.env)

# Note: To change a password, edit /opt/insforge/.env and run update.

# [SECURITY]
# JWT_SECRET= (auto-generated)
# ENCRYPTION_KEY= (auto-generated)

# [ARCANE]
ARCANE_ICON="si:insomnia"
ARCANE_CATEGORY="Development"
