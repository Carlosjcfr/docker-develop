# Windmill Configuration File
# -------------------------------------------------------------
# NOTA: Las variables de entorno críticas y las contraseñas se
# generan en tiempo de despliegue mediante el orquestador .sh
# -------------------------------------------------------------

# --- Versiones (Resolución Dinámica y Core) ---
# Extraídas de la release de Github de Windmill
WINDMILL_VERSION=1.651.1
POSTGRES_VERSION=16
WINDMILL_EXTRA_VERSION=latest

# --- Red y Puertos (Exceptuados 80, 443, 8080, 3552) ---
# Puerto local donde se publicará la UI de Windmill
WINDMILL_PORT=8000
WINDMILL_LSP_PORT=2525

# --- Metadata de Arcane ---
ARCANE_ICON="si:windmill"
ARCANE_CATEGORY="Development"
