# AnyType Cluster Configuration
ANY_SYNC_TOOLS_VERSION=latest
MONGO_VERSION=6.0
REDIS_VERSION=7.0
MINIO_VERSION=latest

# Daemon Versions
ANY_SYNC_COORDINATOR_VERSION=latest
ANY_SYNC_NODE_VERSION=latest
ANY_SYNC_FILENODE_VERSION=latest

# Infrastructure Settings
STORAGE_DIR=./storage

# Network Mapping (Any-Sync Defaults)
ANY_SYNC_COORDINATOR_PORT=1000
ANY_SYNC_COORDINATOR_QUIC_PORT=1001
ANY_SYNC_NODE_1_PORT=1002
ANY_SYNC_NODE_1_QUIC_PORT=1003
ANY_SYNC_NODE_1_API_PORT=8081
ANY_SYNC_FILENODE_PORT=1004
ANY_SYNC_FILENODE_QUIC_PORT=1005

# Arcane Metadata
ARCANE_ICON=si:anytype
ARCANE_CATEGORY=Productivity
